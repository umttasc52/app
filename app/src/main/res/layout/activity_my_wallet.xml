<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".activities.MyWalletActivity">

    <!-- Ana arka plan - tüm ekranı kaplıyor -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/backrondz"
        android:scaleType="centerCrop" />

    <!-- Blockchain pattern overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/blockchain_grid_overlay"
        android:alpha="0.15" />

    <!-- Profesyonel çerçeve border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10dp"
        android:background="@drawable/crypto_frame_border" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical" >

        <include layout="@layout/action_bar" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#304481EA" />

        <!-- Crypto Kart -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginTop="25dp"
            android:visibility="visible"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Kart Arka Planı -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@drawable/crypto_card_bg" />

                <!-- Dünya Haritası Overlay -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/world_map"
                    android:alpha="0.5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="20dp" />

                    <!-- Kart Başlığı -->
                    <TextView
                        android:id="@+id/withNameTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/font1"
                        android:text="@string/paypal"
                        android:textSize="24sp"
                        android:textColor="#64FFDA"
                        android:shadowColor="#80000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="3" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="15dp" />

                    <!-- Dönüşüm Bilgisi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/withConvertTxt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/wallet_convert"
                            android:textSize="18sp"
                            android:textColor="#E2F0FF"
                            android:fontFamily="@font/font1"/>

                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="15dp" />

                    <!-- Ödeme Yöntemi -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wallet_method"
                        android:textSize="14sp"
                        android:textColor="#80E2F0FF"
                        android:fontFamily="@font/font1" />

                    <TextView
                        android:id="@+id/withdrawalMethodTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/font1"
                        android:text="@string/wallet_wallet"
                        android:textSize="18sp"
                        android:textColor="#E2F0FF" />

                    <!-- Dekoratif Çizgi -->
                    <View
                        android:layout_width="100dp"
                        android:layout_height="2dp"
                        android:background="#304481EA"
                        android:layout_marginTop="15dp" />
                </LinearLayout>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- İndikatör Noktaları -->
        <LinearLayout
            android:id="@+id/layoutDots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minHeight="30dp"
            android:orientation="horizontal" />

        <!-- Alt İçerik -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Not Paneli -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="25dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#15234785">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="15dp">

                    <TextView
                        android:id="@+id/withNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/font1"
                        android:text="@string/wallet_alert"
                        android:textColor="#E2F0FF"
                        android:textSize="16sp" />

                    <!-- Dekoratif Çizgi -->
                    <View
                        android:layout_width="80dp"
                        android:layout_height="2dp"
                        android:background="#304481EA"
                        android:layout_marginTop="15dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- İşlem Butonu -->
            <Button
                android:id="@+id/request_btn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/wallet_send"
                android:textColor="#E2F0FF"
                android:textSize="18sp"
                android:background="@drawable/crypto_button_bg"
                android:fontFamily="@font/font1"
                android:textAllCaps="false"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Alt reklamlar -->
    <com.google.android.gms.ads.AdView
        xmlns:ads="http://schemas.android.com/apk/res-auto"
        android:id="@+id/adView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        ads:adSize="BANNER"
        ads:adUnitId="@string/admob_banner_id"/>

    <com.applovin.mediation.ads.MaxAdView
        xmlns:maxads="http://schemas.applovin.com/android/1.0"
        android:id="@+id/MaxAdView"
        maxads:adUnitId="YOUR_ID_HERE"
        android:background="@android:color/transparent"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_width="match_parent"
        android:layout_height="50dp" />
</RelativeLayout>