<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Arka plan -->
    <ImageView
        android:id="@+id/background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/backrondz"
        android:scaleType="centerCrop" />

    <!-- Blockchain pattern overlay -->
    <View
        android:id="@+id/grid_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/blockchain_grid_overlay"
        android:alpha="0.15" />

    <!-- Ana içerik -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_margin="@dimen/spacing_middle"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/bt_close"
                android:layout_width="?attr/actionBarSize"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:srcCompat="@drawable/ic_close"
                app:tint="#64FFDA"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/wallet_request"
                android:fontFamily="@font/font1"
                android:textSize="20sp"
                android:textColor="#64FFDA" />

            <View
                android:layout_width="?attr/actionBarSize"
                android:layout_height="?attr/actionBarSize" />
        </LinearLayout>

        <View
            android:layout_width="@dimen/spacing_large"
            android:layout_height="0dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/your_coinbase_email"
                android:textSize="22sp"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                android:textColor="#64FFDA"
                android:fontFamily="@font/font2"/>

            <EditText
                android:id="@+id/coinbase_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_medium"
                android:hint="@string/email_address"
                android:background="@drawable/crypto_edittext_bg"
                android:padding="12dp"
                android:textColorHint="#80E2F0FF"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                android:textColor="#E2F0FF"
                android:textSize="19sp"
                android:fontFamily="@font/font2"
                tools:ignore="Autofill,TextFields" />
        </LinearLayout>

        <View
            android:layout_width="@dimen/spacing_middle"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/send_request_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/wallet_send"
            android:layout_margin="15dp"
            android:textColor="#E2F0FF"
            android:textSize="17sp"
            android:background="@drawable/crypto_button_bg"
            android:fontFamily="@font/font2"
            android:layout_marginTop="25dp"/>
    </LinearLayout>
</RelativeLayout>