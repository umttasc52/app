<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.SplashActivity">

    <!-- Ana arka plan -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/backrondz"
        android:scaleType="centerCrop" />

    <!-- Blockchain pattern overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/blockchain_grid_overlay"
        android:alpha="0.15" />

    <!-- Profesyonel çerçeve border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10dp"
        android:background="@drawable/crypto_frame_border" />

    <!-- Üst ışık efekti -->
    <View
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/crypto_top_glow" />

    <!-- Alt ışık efekti -->
    <View
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/crypto_bottom_glow" />

    <!-- Dekoratif yatay çizgiler -->
    <View
        android:layout_width="120dp"
        android:layout_height="3dp"
        android:background="#4064FFDA"
        android:layout_above="@id/logo_container"
        android:layout_marginBottom="50dp"
        android:layout_marginStart="30dp" />

    <View
        android:layout_width="80dp"
        android:layout_height="3dp"
        android:background="#4064FFDA"
        android:layout_above="@id/logo_container"
        android:layout_marginBottom="50dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="30dp" />

    <!-- Animasyonlu logo container -->
    <FrameLayout
        android:id="@+id/logo_container"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true"
        android:background="@drawable/crypto_splash_logo_frame">

        <com.mikhaellopez.circularimageview.CircularImageView
            android:id="@+id/app_logo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"

            android:src="@drawable/tokenrm" />

        <!-- Animasyon halkaları -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/crypto_splash_rings"
            android:alpha="0.7" />
    </FrameLayout>

    <!-- Uygulama adı -->
    <TextView
        android:id="@+id/textApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:layout_below="@id/logo_container"
        android:layout_centerHorizontal="true"
        android:textSize="28sp"
        android:textColor="#64FFDA"
        android:fontFamily="@font/font1"
        android:layout_marginTop="20dp"
        android:shadowColor="#80000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="3" />

    <!-- Altındaki tagline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:layout_below="@id/textApp"
        android:layout_centerHorizontal="true"
        android:textSize="14sp"
        android:textColor="#E2F0FF"
        android:fontFamily="@font/font1"
        android:layout_marginTop="5dp" />

    <!-- Loading animasyonu -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="50dp">

        <View
            android:id="@+id/loading_dot1"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/crypto_loading_dot"
            android:layout_margin="5dp" />

        <View
            android:id="@+id/loading_dot2"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/crypto_loading_dot"
            android:layout_margin="5dp" />

        <View
            android:id="@+id/loading_dot3"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/crypto_loading_dot"
            android:layout_margin="5dp" />
    </LinearLayout>

    <!-- No internet include -->
    <include
        layout="@layout/no_internet"
        android:visibility="invisible" />
</RelativeLayout>