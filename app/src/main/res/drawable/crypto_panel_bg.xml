<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:startColor="#0E1B30"
                android:centerColor="#18273F"
                android:endColor="#0E1B30"
                android:angle="135" />
        </shape>
    </item>


    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke android:color="#4481EA" android:width="2dp" />
        </shape>
    </item>

    <item android:left="6dp" android:right="6dp" android:top="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <stroke android:color="#204481EA" android:width="1dp" android:dashWidth="2dp" android:dashGap="8dp" />
        </shape>
    </item>

    <item android:left="30dp" android:right="30dp" android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#204481EA" />
            <size android:height="2dp" />
        </shape>
    </item>
</layer-list>