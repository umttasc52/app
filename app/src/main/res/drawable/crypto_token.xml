<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="100%p"
                android:startColor="#40000000"
                android:endColor="#00000000"
                android:centerX="0.52"
                android:centerY="0.52" />
            <size android:width="60dp" android:height="60dp" />
        </shape>
    </item>

    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#FFEB3B"
                android:centerColor="#FFC107"
                android:endColor="#FF9800" />
        </shape>
    </item>

    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="oval">
            <stroke android:color="#50FFFFFF" android:width="2dp" />
        </shape>
    </item>

    <item android:left="8dp" android:top="5dp" android:right="8dp" android:bottom="25dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#80FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <item android:left="18dp" android:top="12dp" android:right="18dp" android:bottom="18dp">
        <shape android:shape="rectangle">
            <solid android:color="#80000000" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <item android:left="20dp" android:top="20dp" android:right="20dp" android:bottom="15dp">
        <shape android:shape="rectangle">
            <solid android:color="#80000000" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <item android:left="24dp" android:top="25dp" android:right="14dp" android:bottom="20dp">
        <shape android:shape="rectangle">
            <solid android:color="#80000000" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>