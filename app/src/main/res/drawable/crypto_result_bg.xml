<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:startColor="#0C1527"
                android:centerColor="#102040"
                android:endColor="#0C1527"
                android:angle="45" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <stroke android:color="#3570D5" android:width="1.5dp" />
        </shape>
    </item>

    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="60dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="10dp" android:topRightRadius="10dp" />
            <gradient
                android:startColor="#163570D5"
                android:endColor="#00000000"
                android:angle="270" />
        </shape>
    </item>

    <item android:left="20dp" android:right="20dp" android:top="100dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#283570D5" />
            <size android:height="1dp" />
        </shape>
    </item>
</layer-list>