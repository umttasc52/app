<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:startColor="#162540"
                android:centerColor="#0F1C31"
                android:endColor="#071428"
                android:angle="135" />
        </shape>
    </item>

    <item android:top="0dp" android:bottom="110dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="16dp" android:topRightRadius="16dp" />
            <gradient
                android:startColor="#304481EA"
                android:endColor="#00000000"
                android:angle="270" />
        </shape>
    </item>

    <item android:right="150dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="16dp" android:bottomLeftRadius="16dp" />
            <gradient
                android:startColor="#304481EA"
                android:endColor="#00000000"
                android:angle="0" />
        </shape>
    </item>

    <item android:left="200dp" android:top="150dp">
        <shape android:shape="rectangle">
            <corners android:bottomRightRadius="16dp" />
            <solid android:color="#204481EA" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke android:color="#4481EA" android:width="1dp" />
        </shape>
    </item>

    <item android:left="20dp" android:top="20dp" android:right="200dp" android:bottom="200dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="20dp" />
            <stroke android:color="#204481EA" android:width="1dp" />
        </shape>
    </item>

    <item android:left="200dp" android:top="20dp" android:right="20dp" android:bottom="200dp">
        <shape android:shape="rectangle">
            <corners android:topRightRadius="20dp" />
            <stroke android:color="#204481EA" android:width="1dp" />
        </shape>
    </item>
</layer-list>