<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:startColor="#162540"
                android:centerColor="#0F1C31"
                android:endColor="#071428"
                android:angle="135" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke android:color="#304481EA" android:width="1.5dp" />
        </shape>
    </item>

    <item android:top="1dp" android:bottom="60dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="16dp" android:topRightRadius="16dp" />
            <gradient
                android:startColor="#304481EA"
                android:endColor="#00000000"
                android:angle="270" />
        </shape>
    </item>

    <item android:left="5dp" android:top="5dp" android:right="90dp" android:bottom="90dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="10dp" />
            <stroke android:color="#204481EA" android:width="1dp" />
        </shape>
    </item>

    <item android:left="90dp" android:top="5dp" android:right="5dp" android:bottom="90dp">
        <shape android:shape="rectangle">
            <corners android:topRightRadius="10dp" />
            <stroke android:color="#204481EA" android:width="1dp" />
        </shape>
    </item>
</layer-list>