<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="100%p"
                android:startColor="#304481EA"
                android:endColor="#00000000" />
            <size android:width="200dp" android:height="200dp" />
        </shape>
    </item>

    <item android:left="5dp" android:top="5dp" android:right="5dp" android:bottom="5dp">
        <shape android:shape="oval">
            <stroke android:color="#304481EA" android:width="2dp" android:dashWidth="10dp" android:dashGap="5dp" />
        </shape>
    </item>

    <item android:left="20dp" android:top="20dp" android:right="20dp" android:bottom="20dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="100%p"
                android:startColor="#162540"
                android:centerColor="#0F1C31"
                android:endColor="#071428" />
        </shape>
    </item>

    <item android:left="20dp" android:top="20dp" android:right="20dp" android:bottom="20dp">
        <shape android:shape="oval">
            <stroke android:color="#4481EA" android:width="2dp" />
        </shape>
    </item>

    <item android:left="25dp" android:top="20dp" android:right="25dp" android:bottom="90dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#804481EA"
                android:endColor="#00000000"
                android:angle="270" />
        </shape>
    </item>
</layer-list>