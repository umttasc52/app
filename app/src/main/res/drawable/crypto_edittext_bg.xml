<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#162540" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <stroke android:color="#304481EA" android:width="1dp" />
        </shape>
    </item>

    <item android:top="1dp" android:bottom="25dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="12dp" android:topRightRadius="12dp" />
            <gradient
                android:startColor="#304481EA"
                android:endColor="#00000000"
                android:angle="270" />
        </shape>
    </item>
</layer-list>