<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#4481EA"
                android:endColor="#0E1A36"
                android:angle="135" />
            <size android:width="110dp" android:height="110dp" />
        </shape>
    </item>

    <item android:left="5dp" android:top="5dp" android:right="5dp" android:bottom="5dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#162540"
                android:centerColor="#0F1C31"
                android:endColor="#071428"
                android:angle="135" />
        </shape>
    </item>

    <item android:left="10dp" android:top="10dp" android:right="10dp" android:bottom="10dp">
        <shape android:shape="oval">
            <stroke android:color="#304481EA" android:width="1dp" android:dashWidth="8dp" android:dashGap="4dp" />
        </shape>
    </item>

    <item android:left="10dp" android:top="5dp" android:right="10dp" android:bottom="60dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#804481EA"
                android:endColor="#00000000"
                android:angle="270" />
        </shape>
    </item>
</layer-list>