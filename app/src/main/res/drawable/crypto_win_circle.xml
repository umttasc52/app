<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#64FFDA"
                android:endColor="#009688"
                android:angle="135" />
            <size android:width="110dp" android:height="110dp" />
        </shape>
    </item>

    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#162540"
                android:centerColor="#0F1C31"
                android:endColor="#071428"
                android:angle="135" />
        </shape>
    </item>

    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="50dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#3064FFDA"
                android:endColor="#00000000"
                android:angle="270" />
        </shape>
    </item>

    <item android:left="25dp" android:top="20dp" android:right="25dp" android:bottom="40dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <stroke android:color="#3064FFDA" android:width="2dp" />
        </shape>
    </item>
</layer-list>